{
  "name": "hor-ai-assist-fun",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm run type-check && npm run transpile",
    "build:fast": "npm run transpile",
    "transpile": "node esbuild-config.js",
    "type-check": "tsc --noEmit",
    "test": "npm run type-check && jest",
    "test:fast": "jest",
    "dev:watch": "concurrently \"tsc --noEmit --watch\" \"nodemon esbuild-config.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-crypto/sha256-browser": "^5.2.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-bedrock-runtime": "^3.782.0",
    "@aws-sdk/client-eventbridge": "^3.873.0",
    "@aws-sdk/client-sts": "^3.876.0",
    "@aws-sdk/credential-providers": "^3.876.0",
    "@aws-sdk/protocol-http": "^3.370.0",
    "@aws-sdk/signature-v4": "^3.370.0",
    "@eslint/js": "^9.39.1",
    "@fullbay/idp-commonutil-node-lib": "^1.0.22",
    "aws-lambda": "^1.0.7",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "eslint": "^9.39.1",
    "mysql2": "^3.14.3"
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.936.0",
    "@types/aws-lambda": "^8.10.148",
    "@types/jest": "^29.5.0",
    "@types/jest-when": "^3.5.5",
    "@types/node": "^22.14.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "concurrently": "^9.2.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.48.1",
    "esbuild": "^0.25.12",
    "esbuild-plugin-tsc": "^0.5.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "jest": "^29.7.0",
    "jest-when": "^3.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>",
      "src/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/build/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,js}",
      "!src/**/*.test.{ts,js}",
      "!src/**/*.spec.{ts,js}",
      "!src/localTests/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFiles": [
      "<rootDir>/src/tests/test-setup-env.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/jest.setup.ts"
    ],
    "testTimeout": 10000,
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "extensionsToTreatAsEsm": []
  }
}
